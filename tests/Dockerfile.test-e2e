# SPDX-License-Identifier: Apache-2.0
# tests/Dockerfile.test-e2e — fixture for the end-to-end install + skill test.
#
# Built and run from CI by .github/workflows/e2e.yml. Locally:
#
#   docker build -t diecast-e2e -f tests/Dockerfile.test-e2e .
#   docker run --rm -v "$(pwd):/work" diecast-e2e
#
# The repo is mounted at /work at runtime (not COPYed) so any branch
# can be tested without rebuilding the image.

FROM python:3.12-slim

# Tools: bash >= 4.0 (Decision #4), git >= 2.30, curl for uv install.
RUN apt-get update && apt-get install -y --no-install-recommends \
        git curl ca-certificates bash procps \
    && rm -rf /var/lib/apt/lists/*

# uv (Diecast prereq).
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# Fake claude binary so install plumbing tests don't need real Claude Code
# (Decision #8). The mounted repo carries the source-of-truth fake; we copy
# at build time so a `which claude` works before the volume mount lands.
COPY tests/fixtures/fake-claude /usr/local/bin/claude
RUN chmod +x /usr/local/bin/claude

# Repo lands at /work via -v at runtime.
WORKDIR /work

# Default entrypoint runs the orchestrator. Override for shell-into debug
# with `docker run -it --entrypoint bash diecast-e2e`.
CMD ["bash", "tests/e2e-test.sh"]
