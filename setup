#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
# setup — Diecast installer.
#
# Takes a fresh clone of
# github.com/sridherj/diecast on a machine with `uv` + `git` + Claude Code
# and produces a usable Diecast install in under 90 seconds.
#
# Usage:
#   ./setup                # full install with $CAST_TERMINAL prompt
#   ./setup --dry-run      # print the action plan without touching the filesystem
#   ./setup --upgrade      # rerun path used by /cast-upgrade (sp2b)
#   ./setup --no-prompt    # skip the $CAST_TERMINAL prompt (CI / non-interactive)
#   ./setup --help         # this help
#
# Pre-existing files at install targets are backed up under
# ~/.claude/.cast-bak-<UTC-timestamp>/ before being overwritten.
# The 5 newest backup directories are retained; the rest are pruned.
#
# ── $CAST_TERMINAL prompt: dual interactive paths ──
# 1. Claude Code branch: ./setup invoked from inside a Claude Code session that
#    has the diecast repo loaded (CAST_INTERACTIVE=1) → use cast-interactive-questions
#    (richer rendering via AskUserQuestion).
# 2. Pure shell branch: ./setup invoked from a plain terminal → use bash `read -rp`.
# Do NOT collapse the two paths. Pure shell installs are the dominant first-touch case.

set -euo pipefail

REPO_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
# shellcheck source=bin/_lib.sh
source "${REPO_DIR}/bin/_lib.sh"

DRY_RUN="${DRY_RUN:-0}"
UPGRADE_MODE=0
NO_PROMPT=0

print_help() {
  cat <<'EOF'
setup — Diecast installer.

Usage:
  ./setup                # full install with $CAST_TERMINAL prompt
  ./setup --dry-run      # print the action plan without touching the filesystem
  ./setup --upgrade      # rerun path used by /cast-upgrade (sp2b)
  ./setup --no-prompt    # skip the $CAST_TERMINAL prompt (CI / non-interactive)
  ./setup --help         # this help

Pre-existing files at install targets are backed up under
~/.claude/.cast-bak-<UTC-timestamp>/ before being overwritten. The 5 newest
backup directories are retained; the rest are pruned. See docs/config.md
for the full ~/.cast/config.yaml schema.
EOF
}

while (($#)); do
  case "$1" in
    --dry-run)   DRY_RUN=1 ;;
    --upgrade)   UPGRADE_MODE=1 ;;
    --no-prompt) NO_PROMPT=1 ;;
    -h|--help)   print_help; exit 0 ;;
    *) fail "Unknown flag: $1 (try --help)" ;;
  esac
  shift
done
export DRY_RUN UPGRADE_MODE NO_PROMPT REPO_DIR

if [[ "${UPGRADE_MODE}" == "1" ]]; then
  log "Upgrade run (called by /cast-upgrade or rerun)."
else
  log "First install (or manual rerun)."
fi
[[ "${DRY_RUN}" == "1" ]] && log "Dry-run mode — no filesystem changes."

# ── Helper: run a step in dry-run-aware fashion ───────────────────
run_or_dry() {
  if [[ "${DRY_RUN}" == "1" ]]; then
    log "DRY: $*"
  else
    "$@"
  fi
}

# ── Step 1: prereqs via cast-doctor ────────────────────────────────
step1_doctor() {
  log "Step 1/8: prerequisite check (bin/cast-doctor)"
  if ! "${REPO_DIR}/bin/cast-doctor"; then
    fail "Prerequisites missing. Resolve the [RED] items above and re-run ./setup."
  fi
}

# ── Step 2: generate-skills + anti-leak grep ───────────────────────
step2_generate_skills() {
  log "Step 2/8: generate Claude Code skill files (bin/generate-skills)"
  local skills_target="${HOME}/.claude/skills"
  if [[ "${DRY_RUN}" == "1" ]]; then
    "${REPO_DIR}/bin/generate-skills" --dry-run --target-dir "${skills_target}"
  else
    "${REPO_DIR}/bin/generate-skills" --target-dir "${skills_target}"
  fi

  # Anti-leak: bail if any generated skill still references 'taskos-'.
  local leak_root="${REPO_DIR}/skills/claude-code"
  if [[ -d "${leak_root}" ]]; then
    if grep -rl 'taskos-' "${leak_root}"/cast-* >/dev/null 2>&1; then
      fail "Anonymization leak: generated skills still reference 'taskos-'. See docs/troubleshooting.md."
    fi
  fi
}

# ── Step 2.5: schema migrations (upgrade-only) ─────────────────────
# Runs only on `./setup --upgrade`. Fresh installs have no schema to
# migrate. The runner reads ~/.cast/migrations.applied, computes the
# diff against migrations/*.py, and applies un-applied migrations in
# lex order. v1 ships zero migrations; this seam keeps the v1.1 hook
# wired without later install-flow surgery.
step2_5_migrations() {
  if [[ "${UPGRADE_MODE}" != "1" ]]; then
    return 0
  fi
  log "Step 2.5/8: run schema migrations (bin/run-migrations.py)"
  if [[ "${DRY_RUN}" == "1" ]]; then
    "${REPO_DIR}/bin/run-migrations.py" --dry-run
  else
    "${REPO_DIR}/bin/run-migrations.py"
  fi
}

# ── Step 3: install agents under ~/.claude/agents/cast-* ───────────
step3_install_agents() {
  log "Step 3/8: install agents -> ~/.claude/agents/"
  local target_root="${HOME}/.claude/agents"
  run_or_dry mkdir -p "${target_root}"

  local agent_dir name
  for agent_dir in "${REPO_DIR}/agents"/cast-*/; do
    [[ -d "${agent_dir}" ]] || continue
    name="$(basename "${agent_dir}")"
    backup_if_exists "${target_root}/${name}"
    if [[ "${DRY_RUN}" == "1" ]]; then
      log "DRY: cp -R ${agent_dir} ${target_root}/${name}"
    else
      cp -R "${agent_dir}" "${target_root}/${name}"
    fi
  done
}

# ── Step 4: install authored skills under ~/.claude/skills/cast-* ──
step4_install_skills() {
  log "Step 4/8: install hand-authored skills -> ~/.claude/skills/"
  local source_root="${REPO_DIR}/skills/claude-code"
  local target_root="${HOME}/.claude/skills"
  [[ -d "${source_root}" ]] || { log "  (no skills/claude-code/ in repo, skipping)"; return 0; }
  run_or_dry mkdir -p "${target_root}"

  local skill_dir name
  for skill_dir in "${source_root}"/cast-*/; do
    [[ -d "${skill_dir}" ]] || continue
    name="$(basename "${skill_dir}")"
    backup_if_exists "${target_root}/${name}"
    if [[ "${DRY_RUN}" == "1" ]]; then
      log "DRY: cp -R ${skill_dir} ${target_root}/${name}"
    else
      cp -R "${skill_dir}" "${target_root}/${name}"
    fi
  done
}

# ── Step 5: remove legacy ~/.local/bin/cast-server shim ────────────
# The PATH-based shim is gone; binaries are now reached through the
# ~/.claude/skills/diecast/ umbrella (Step 5a). Backup-then-remove instead of
# silent delete so the user can recover the old wrapper from .cast-bak-<ts>/.
step5_remove_legacy_shim() {
  log "Step 5/8: remove legacy ~/.local/bin/cast-server shim (gstack pattern)"
  backup_if_exists "${HOME}/.local/bin/cast-server"
}

# ── Step 5a: ~/.claude/skills/diecast symlink (gstack-pattern install seam) ─
# Make bin/cast-server and bin/cast-hook reachable as
#   ~/.claude/skills/diecast/bin/cast-server
#   ~/.claude/skills/diecast/bin/cast-hook
# without touching PATH. The hook installer (cast_server.cli.install_hooks)
# writes that absolute path into .claude/settings.json so hooks fire
# regardless of shell PATH composition.
step5a_install_diecast_skill_root() {
  log "Step 5a/8: install ~/.claude/skills/diecast symlink (gstack pattern)"
  install_diecast_skill_root "${REPO_DIR}"
}

# ── Step 5b: alembic upgrade head ──────────────────────────────────
# Runs migrations against ~/.cast/diecast.db before the server is allowed to launch.
# Boot-time `_ensure_db_at_head()` (sp3, Decision #15) is the second line of defense;
# this is the first. A failed migration aborts setup verbatim — refuse to launch a
# possibly-broken DB.
step5b_run_migrations() {
  log "Step 5b/8: run database migrations (alembic upgrade head)"
  if [[ "${DRY_RUN}" == "1" ]]; then
    log "DRY: (cd ${REPO_DIR}/cast-server && uv run alembic upgrade head)"
    return 0
  fi
  ( cd "${REPO_DIR}/cast-server" && uv run alembic upgrade head ) \
    || fail "alembic upgrade head failed; refusing to launch with possibly-broken DB"
}

# ── Step 6: write ~/.cast/config.yaml on first run ─────────────────
# Canonical schema lives in docs/config.md and _shared_context.md.
# If the file exists, fill in any missing keys with defaults but preserve user values.
step6_write_config() {
  log "Step 6/8: ~/.cast/config.yaml"
  local cfg_dir="${HOME}/.cast"
  local cfg_file="${cfg_dir}/config.yaml"
  run_or_dry mkdir -p "${cfg_dir}"

  if [[ "${DRY_RUN}" == "1" ]]; then
    if [[ -f "${cfg_file}" ]]; then
      log "DRY: merge missing default keys into ${cfg_file}"
    else
      log "DRY: write canonical schema to ${cfg_file}"
    fi
    return 0
  fi

  # Use uv-managed Python so we don't depend on system PyYAML.
  local merger
  merger="$(mktemp)"
  cat > "${merger}" <<'PY'
import sys
from pathlib import Path
import yaml

DEFAULTS = {
    "terminal": "",
    "host": "localhost",
    "port": 8005,
    "auto_upgrade": False,
    "upgrade_snooze_until": None,
    "upgrade_snooze_streak": 0,
    "upgrade_never_ask": False,
    "last_upgrade_check_at": None,
    "proactive_global": None,
    "proactive_overrides": {},
}

HEADER = (
    "# ~/.cast/config.yaml — Diecast user-level config.\n"
    "# Schema reference: docs/config.md inside the diecast repo.\n"
    "# Edits here are preserved by ./setup re-runs and /cast-upgrade.\n"
)


def main(path: str, terminal_seed: str = "") -> None:
    p = Path(path)
    if p.exists():
        raw = yaml.safe_load(p.read_text()) or {}
        if not isinstance(raw, dict):
            raw = {}
    else:
        raw = {}
    merged = {}
    for key, default in DEFAULTS.items():
        if key in raw:
            merged[key] = raw[key]
        else:
            merged[key] = default
    if terminal_seed and not merged.get("terminal"):
        merged["terminal"] = terminal_seed
    p.write_text(HEADER + yaml.safe_dump(merged, sort_keys=False))


if __name__ == "__main__":
    main(*sys.argv[1:])
PY

  uv run --project "${REPO_DIR}" python "${merger}" "${cfg_file}" "${CAST_TERMINAL:-}" \
    || { rm -f "${merger}"; fail "Failed to write ${cfg_file}. Check that uv + pyyaml are available."; }
  rm -f "${merger}"
  log "  wrote/merged ${cfg_file}"
}

# ── Step 7: $CAST_TERMINAL prompt ──────────────────────────────────
persist_terminal_choice() {
  local choice="$1"
  [[ -z "${choice}" || "${choice}" == "skip" ]] && return 0
  if [[ "${DRY_RUN}" == "1" ]]; then
    log "DRY: persist terminal=${choice} into ~/.cast/config.yaml"
    return 0
  fi
  local merger
  merger="$(mktemp)"
  cat > "${merger}" <<'PY'
import sys
from pathlib import Path
import yaml

p = Path(sys.argv[1])
choice = sys.argv[2]
data = {}
if p.exists():
    data = yaml.safe_load(p.read_text()) or {}
    if not isinstance(data, dict):
        data = {}
data["terminal"] = choice
p.write_text(yaml.safe_dump(data, sort_keys=False))
PY
  uv run --project "${REPO_DIR}" python "${merger}" "${HOME}/.cast/config.yaml" "${choice}" \
    || warn "Failed to persist terminal=${choice}"
  rm -f "${merger}"
}

step7_terminal_prompt() {
  log "Step 7/8: \$CAST_TERMINAL preference"
  if [[ -n "${CAST_TERMINAL:-}" ]]; then
    log "  \$CAST_TERMINAL already set to '${CAST_TERMINAL}' — skipping prompt."
    return 0
  fi
  if [[ "${NO_PROMPT}" == "1" ]]; then
    log "  --no-prompt: leaving terminal preference empty."
    return 0
  fi
  if [[ ! -t 0 ]]; then
    warn "Non-interactive shell — terminal preference left empty. Override via CAST_TERMINAL=... ./setup."
    return 0
  fi

  if [[ "${CAST_INTERACTIVE:-0}" == "1" ]] && command -v claude >/dev/null 2>&1; then
    log "  Claude Code branch: invoke /cast-interactive-questions for terminal selection."
    log "  (Setup defers — the host runs the AskUserQuestion prompt separately.)"
    return 0
  fi

  local choice=""
  printf '\n[cast] Select default terminal for child agent dispatch:\n' >&2
  printf '  Options: gnome-terminal, iterm2, kitty, alacritty, wezterm, ptyxis, skip\n' >&2
  read -rp "Choice [skip]: " choice
  choice="${choice:-skip}"
  persist_terminal_choice "${choice}"
}

# ── Step 8: launch cast-server + open dashboard ───────────────────
# The user-visible payoff. Skip on UPGRADE_MODE / DRY_RUN / NO_PROMPT / CI / already-running.
# Decision #4 (drop disown), #10 (30×0.5s readiness), #11 (cache dir on happy path),
# #13 (bootstrap.log vs server.log split). Never fails setup over the launch step.
_open_browser() {
  local url="$1"
  case "$(uname -s)" in
    Darwin) open "${url}" 2>/dev/null || true ;;
    Linux)
      if [[ -n "${DISPLAY:-}${WAYLAND_DISPLAY:-}" ]] && command -v xdg-open >/dev/null 2>&1; then
        xdg-open "${url}" >/dev/null 2>&1 &
      else
        log "  no display detected — visit ${url} manually"
      fi
      ;;
    *) log "  unsupported OS for browser open — visit ${url} manually" ;;
  esac
}

step8_launch_and_open_browser() {
  log "Step 8/8: launch cast-server + open dashboard"

  local host="${CAST_HOST:-localhost}"
  local port="${CAST_PORT:-8005}"
  local url="http://${host}:${port}/"

  # Skip conditions (any one short-circuits this step).
  if [[ "${UPGRADE_MODE}" == "1" ]]; then
    log "  skipping launch: --upgrade mode"
    LAUNCHED=0; return 0
  fi
  if [[ "${DRY_RUN}" == "1" ]]; then
    log "  skipping launch: --dry-run"
    LAUNCHED=0; return 0
  fi
  if [[ "${NO_PROMPT}" == "1" ]] || [[ -n "${CI:-}" ]]; then
    log "  skipping launch: non-interactive (--no-prompt or CI)"
    LAUNCHED=0; return 0
  fi

  # Port pre-flight probe.
  if exec 3<>"/dev/tcp/${host}/${port}" 2>/dev/null; then
    exec 3<&-; exec 3>&-
    # Something is bound. Determine whether it is our cast-server.
    if curl -s --max-time 1 "${url}api/agents/runs?status=running" >/dev/null 2>&1; then
      log "  cast-server already running on ${host}:${port}; opening browser only"
      LAUNCHED=1
      _open_browser "${url}"
      return 0
    fi
    # Bound by something else.
    local pid="" cmd="?"
    if command -v lsof >/dev/null 2>&1; then
      pid="$(lsof -ti ":${port}" 2>/dev/null | head -1 || true)"
    elif command -v ss >/dev/null 2>&1; then
      pid="$(ss -tlnp "sport = :${port}" 2>/dev/null \
        | sed -n 's/.*pid=\([0-9][0-9]*\).*/\1/p' | head -1 || true)"
    elif command -v fuser >/dev/null 2>&1; then
      pid="$(fuser "${port}/tcp" 2>/dev/null | awk '{print $1}' || true)"
    fi
    if [[ -n "${pid}" ]]; then
      cmd="$(ps -p "${pid}" -o comm= 2>/dev/null || echo "?")"
    fi
    warn "port ${port} in use by PID ${pid:-?} (${cmd})."
    warn "       set CAST_PORT=<n> ./setup, or stop the process and re-run."
    warn "       (skipping launch — install otherwise complete)"
    LAUNCHED=0
    return 0
  fi

  # Happy path: nothing on the port. Touch the cache dir only here (Decision #11).
  mkdir -p "${HOME}/.cache/diecast"

  # Detached background launch (Decision #4 — drop disown; Decision #13 — bootstrap.log).
  ( nohup "${HOME}/.claude/skills/diecast/bin/cast-server" \
        >"${HOME}/.cache/diecast/bootstrap.log" 2>&1 & ) >/dev/null 2>&1

  # Readiness poll: 30 × 0.5s = 15s (Decision #10).
  local i
  for i in $(seq 1 30); do
    if exec 3<>"/dev/tcp/${host}/${port}" 2>/dev/null; then
      exec 3<&-; exec 3>&-
      LAUNCHED=1
      break
    fi
    sleep 0.5
  done

  if [[ "${LAUNCHED}" != "1" ]]; then
    warn "cast-server did not become ready within 15s."
    warn "       check ${HOME}/.cache/diecast/bootstrap.log for startup errors."
    LAUNCHED=0
    return 0   # never fail setup over the launch step
  fi

  # Terminal wire-up (skipped on --no-prompt / CI — already filtered above).
  if [[ -x "${REPO_DIR}/bin/cast-doctor" ]]; then
    "${REPO_DIR}/bin/cast-doctor" --fix-terminal \
      || warn "  bin/cast-doctor --fix-terminal returned non-zero (continuing)"
  fi

  _open_browser "${url}"

}

# ── Typed next_steps printout (two-branch: running vs deferred) ───
print_next_steps() {
  local host="${CAST_HOST:-localhost}"
  local port="${CAST_PORT:-8005}"
  local url="http://${host}:${port}"

  if [[ "${LAUNCHED}" == "1" ]]; then
    cat <<EOF

[cast] Install complete. cast-server is running at ${url}
       (logs: ~/.cache/diecast/server.log; bootstrap: ~/.cache/diecast/bootstrap.log)

Binaries (no PATH pollution; reach via the diecast skill-root symlink):
  ~/.claude/skills/diecast/bin/cast-server
  ~/.claude/skills/diecast/bin/cast-hook

To restart cast-server later (e.g. after reboot):
  ~/.claude/skills/diecast/bin/cast-server                            # background-friendly defaults
  CAST_PORT=8080 ~/.claude/skills/diecast/bin/cast-server             # custom port
  CAST_BIND_HOST=0.0.0.0 ~/.claude/skills/diecast/bin/cast-server     # bind for LAN access (server side)

Next steps:
  1. /cast-init   — scaffold a new project (writes CLAUDE.md + cast-* dirs)
  2. /cast-runs   — open the dashboard you just launched

Docs: docs/config.md (config keys) · docs/troubleshooting.md (recovery & FAQ)
EOF
  else
    cat <<EOF

[cast] Install complete. To start the server:
  ~/.claude/skills/diecast/bin/cast-server

Next steps:
  1. /cast-init   — scaffold a new project (writes CLAUDE.md + cast-* dirs)
  2. /cast-runs   — open the dashboard once cast-server is up

Docs: docs/config.md (config keys) · docs/troubleshooting.md (recovery & FAQ)
EOF
  fi
}

# ── Run ────────────────────────────────────────────────────────────
LAUNCHED=0
step1_doctor
step2_generate_skills
step2_5_migrations
step3_install_agents
step4_install_skills
step5_remove_legacy_shim
step5a_install_diecast_skill_root
step5b_run_migrations
step6_write_config
step7_terminal_prompt
prune_old_backups
step8_launch_and_open_browser
print_next_steps
