#!/usr/bin/env python3
"""Print the best available terminal for this host, or empty string if none found.

Called by setup/step6 and bin/cast-doctor --fix-terminal.
Single source of truth: delegates to agents._shared.terminal._autodetect().
"""
import sys
from pathlib import Path

# Add the repo root to sys.path so `agents._shared.terminal` is importable.
# Aligned with the pattern used in cast_server.bootstrap.doctor.
_repo_root = str(Path(__file__).resolve().parent.parent)
if _repo_root not in sys.path:
    sys.path.insert(0, _repo_root)
from agents._shared.terminal import _autodetect

candidates = _autodetect()
print(candidates[0] if candidates else "", end="")
