#!/usr/bin/env bash
# Generated entry point for the cast-hook console script.
# Mirrors bin/cast-server: routes through `uv run` so .venv lifecycle is
# managed by uv and we don't depend on .venv/ already existing at install
# time. The console script itself is declared in pyproject.toml's
# [project.scripts] table and produced inside the project venv.
set -euo pipefail

REPO_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd -P)"
exec uv run --project "${REPO_DIR}" -- cast-hook "$@"
