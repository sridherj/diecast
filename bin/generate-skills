#!/usr/bin/env python3
# SPDX-License-Identifier: Apache-2.0
"""Materialize Claude Code skill files from Diecast agents and skills.

Discovers `cast-*` subdirectories under ``agents/`` and ``skills/claude-code/``
and writes a ``SKILL.md`` per entry into the target directory (default
``~/.claude/skills``). Pre-existing target files are moved to
``<target>/.cast-bak-<timestamp>/`` before overwrite, where ``<timestamp>`` is
constant for a single invocation.

Usage:
    bin/generate-skills                       # write to ~/.claude/skills
    bin/generate-skills --dry-run             # preview, no filesystem changes
    bin/generate-skills --target-dir <path>   # override target directory

# TODO(Phase 4): Checksum-aware overwrite path. Today every run rewrites
# every target file byte-for-byte; user edits to <target>/cast-*/SKILL.md
# are silently overwritten (with the safety net of .cast-bak-<timestamp>/).
# Refined-req US8 owns the upgrade-preserves-mods story — see
# refined_requirements.collab.md and bin/README.md.
#
# TODO(Phase 4): `.cast-bak-*` cleanup is left to the user / cast-upgrade.
# This script never deletes backup folders, so they accumulate. Phase 4
# `/cast-upgrade` will own a prune policy. Documented in bin/README.md.
"""

from __future__ import annotations

import argparse
import datetime as _dt
import shutil
import sys
from dataclasses import dataclass
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
DEFAULT_TARGET = Path('~/.claude/skills').expanduser()

AGENTS_DIR = REPO_ROOT / 'agents'
SKILLS_DIR = REPO_ROOT / 'skills' / 'claude-code'

GENERATED_HEADER = '<!-- Generated by bin/generate-skills — do not edit -->\n'


@dataclass(frozen=True)
class Source:
    """A single agent or skill to materialize."""

    kind: str  # "agent" or "skill"
    name: str  # cast-* directory name
    source_path: Path  # absolute path to the source .md / SKILL.md


def _discover(root: Path, kind: str, filename_hint: str | None) -> tuple[list[Source], list[str]]:
    """Find cast-* subdirs under ``root`` and return Sources plus skip warnings.

    For agents, the source file is ``<root>/cast-foo/cast-foo.md``.
    For skills, the source file is ``<root>/cast-foo/SKILL.md``.
    """
    sources: list[Source] = []
    warnings: list[str] = []
    if not root.is_dir():
        return sources, warnings

    for child in sorted(root.iterdir()):
        if not child.is_dir():
            continue
        if not child.name.startswith('cast-'):
            warnings.append(
                f'skipped non-cast-* {kind} directory: {child.relative_to(REPO_ROOT)}'
            )
            continue

        if kind == 'agent':
            candidate = child / f'{child.name}.md'
        else:
            candidate = child / (filename_hint or 'SKILL.md')

        if not candidate.is_file():
            warnings.append(
                f'skipped {kind} {child.name}: missing {candidate.name}'
            )
            continue

        sources.append(Source(kind=kind, name=child.name, source_path=candidate))

    return sources, warnings


def discover_sources(repo_root: Path) -> tuple[list[Source], list[str]]:
    """Discover all agents and skills under repo_root. Returns (sources, warnings)."""
    agents_root = repo_root / 'agents'
    skills_root = repo_root / 'skills' / 'claude-code'
    agent_sources, agent_warnings = _discover(agents_root, 'agent', None)
    skill_sources, skill_warnings = _discover(skills_root, 'skill', 'SKILL.md')
    return agent_sources + skill_sources, agent_warnings + skill_warnings


def render(source: Source, repo_root: Path) -> str:
    """Render the SKILL.md content for a source: header + back-reference + body."""
    rel = source.source_path.relative_to(repo_root)
    body = source.source_path.read_text(encoding='utf-8')
    back_ref = f'<!-- Source: {rel} -->\n'
    return GENERATED_HEADER + back_ref + body


def _backup_existing(target_file: Path, target_root: Path, backup_root: Path) -> Path | None:
    """Move ``target_file`` into the per-invocation backup folder, preserving its relative path.

    Returns the backup destination path, or None if no file existed.
    """
    if not target_file.exists():
        return None
    rel = target_file.relative_to(target_root)
    dest = backup_root / rel
    dest.parent.mkdir(parents=True, exist_ok=True)
    shutil.move(str(target_file), str(dest))
    return dest


def write_outputs(
    sources: list[Source],
    target_root: Path,
    repo_root: Path,
    *,
    dry_run: bool,
    timestamp: str,
) -> tuple[int, list[Path]]:
    """Write SKILL.md files for each source. Returns (write_count, backup_paths)."""
    backup_root = target_root / f'.cast-bak-{timestamp}'
    backups: list[Path] = []
    written = 0

    for source in sources:
        target_file = target_root / source.name / 'SKILL.md'
        content = render(source, repo_root)

        if dry_run:
            written += 1
            if target_file.exists():
                backups.append(target_file)  # not a real backup path; just signal
            continue

        backup_path = _backup_existing(target_file, target_root, backup_root)
        if backup_path is not None:
            backups.append(backup_path)
        target_file.parent.mkdir(parents=True, exist_ok=True)
        target_file.write_text(content, encoding='utf-8')
        written += 1

    return written, backups


def _format_timestamp(now: _dt.datetime | None = None) -> str:
    now = now or _dt.datetime.now()
    return now.strftime('%Y%m%d-%H%M%S')


def run(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog='generate-skills',
        description=(
            'Materialize Claude Code skill files from cast-* agents and skills '
            'into ~/.claude/skills (or --target-dir).'
        ),
    )
    parser.add_argument(
        '--dry-run',
        action='store_true',
        help='Print actions without making any filesystem changes.',
    )
    parser.add_argument(
        '--target-dir',
        type=Path,
        default=DEFAULT_TARGET,
        help='Override the output directory (default: ~/.claude/skills).',
    )
    args = parser.parse_args(argv)

    sources, warnings = discover_sources(REPO_ROOT)

    for w in warnings:
        print(f'warning: {w}', file=sys.stderr)

    agent_count = sum(1 for s in sources if s.kind == 'agent')
    skill_count = sum(1 for s in sources if s.kind == 'skill')

    if not sources:
        print(f'Found {agent_count} agents, {skill_count} skills — nothing to generate')
        return 0

    target_root: Path = args.target_dir
    timestamp = _format_timestamp()

    if not args.dry_run:
        target_root.mkdir(parents=True, exist_ok=True)

    written, backups = write_outputs(
        sources,
        target_root=target_root,
        repo_root=REPO_ROOT,
        dry_run=args.dry_run,
        timestamp=timestamp,
    )

    mode = 'would write' if args.dry_run else 'wrote'
    print(
        f'{mode} {written} SKILL.md files '
        f'({agent_count} agents, {skill_count} skills) to {target_root}'
    )
    if backups and not args.dry_run:
        print(f'backed up {len(backups)} pre-existing file(s) to {target_root}/.cast-bak-{timestamp}')
    return 0


if __name__ == '__main__':
    sys.exit(run())
