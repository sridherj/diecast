#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd -P)"

exec uv run --project "${REPO_DIR}" -- uvicorn cast_server.app:app \
  --app-dir "${REPO_DIR}/cast-server" \
  --host "${CAST_BIND_HOST:-127.0.0.1}" \
  --port "${CAST_PORT:-8005}" \
  "$@"
