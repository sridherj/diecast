#!/usr/bin/env python3
"""Anonymization lint for the Diecast public repo.

Scans tracked + untracked files (respecting .gitignore via `git ls-files`,
falling back to a `pathlib` walk outside a git repo) for upstream-private
references that must not appear in public Diecast output. Run before pushing;
CI runs this on every push and pull request (see
`.github/workflows/anonymization-lint.yml`).

Usage:
    bin/lint-anonymization [--root <path>] [--include-fixtures]

Exit codes:
    0  no forbidden patterns found
    1  one or more hits (printed one per line)
    2  invocation error
"""

from __future__ import annotations

import argparse
import re
import subprocess
import sys
import time
from pathlib import Path
from typing import Iterable, List, Tuple

# ---------------------------------------------------------------------------
# Forbidden patterns.
#
# Each entry is (regex, flags). Lines in this file that contain a pattern
# regex literal carry the `# diecast-lint: ignore-line` self-exemption marker
# so the lint does not flag itself. Decision D6 (refined_requirements):
# the forbidden list lives in-script — any external file would itself need
# to be public, defeating the point.
#
# Deviation note (Phase 1.3 implementation): the spec listed `r"sridherj"`  # diecast-lint: ignore-line
# as the bare pattern. The repository is hosted at github.com/sridherj/diecast
# (the GitHub org name is unavoidably public), so a literal substring match
# triples-up false positives on legitimate URLs in CONTRIBUTING.md, README.md,
# SECURITY.md, etc. The pattern below carries a negative lookbehind /
# lookahead that exempts the canonical public URL context only. Any other
# occurrence still fires.
#
# Quarterly review (per CONTRIBUTING.md): if the upstream private  # diecast-lint: ignore-line
# CLAUDE.md `## People` table is updated, append a `\b<First Last>\b` entry  # diecast-lint: ignore-line
# below. As of 2026-04-30 the People table is empty.
# ---------------------------------------------------------------------------

FORBIDDEN_PATTERNS: List[Tuple[str, int]] = [
    # `\b` is load-bearing here: bare "SJ" can appear inside legitimate  # diecast-lint: ignore-line
    # identifiers (e.g. variable names like `tsjson` or `JSJSession`), and  # diecast-lint: ignore-line
    # without word boundaries the lint would produce noisy false positives
    # on innocuous code. The boundary anchors keep the rule precise.
    (r"\bSJ\b", 0),                                                # diecast-lint: ignore-line
    # `sridherj` with negative lookbehind/lookahead exempting the canonical  # diecast-lint: ignore-line
    # public-repo URL form `github.com[:/]sridherj/diecast`. See deviation  # diecast-lint: ignore-line
    # note above. Any other occurrence (bare name, email, alt path) still hits.
    (r"(?<!github\.com/)(?<!github\.com:)sridherj(?!/diecast)", re.IGNORECASE),  # diecast-lint: ignore-line
    (r"sridherj@gmail\.com", re.IGNORECASE),                       # diecast-lint: ignore-line
    (r"/data/workspace/second-brain", 0),                          # diecast-lint: ignore-line
    (r"~/workspace/linkedout-oss", 0),                             # diecast-lint: ignore-line
    (r"~/workspace/second-brain", 0),                              # diecast-lint: ignore-line
    (r"\babout_me/", 0),                                           # diecast-lint: ignore-line
    (r"\bptyxis\b", re.IGNORECASE),                                # diecast-lint: ignore-line
    # Personal-agent names from refined-req US3 exclusion set. Match both bare
    # and `taskos-` prefixed forms.
    (r"\b(?:taskos-)?linkedin-ai\b", 0),                           # diecast-lint: ignore-line
    (r"\b(?:taskos-)?reachout-packet\b", 0),                       # diecast-lint: ignore-line
    (r"\b(?:taskos-)?opportunity-finder\b", 0),                    # diecast-lint: ignore-line
    (r"\b(?:taskos-)?startup-discover\b", 0),                      # diecast-lint: ignore-line
    (r"\b(?:taskos-)?startup-enrich\b", 0),                        # diecast-lint: ignore-line
    (r"\b(?:taskos-)?startup-pipeline\b", 0),                      # diecast-lint: ignore-line
    (r"\b(?:taskos-)?generate-news-digest\b", 0),                  # diecast-lint: ignore-line
    (r"\b(?:taskos-)?google-alert-setup\b", 0),                    # diecast-lint: ignore-line
    # ## People-table forbidden names go here when the upstream private  # diecast-lint: ignore-line
    # CLAUDE.md People table is populated. Empty as of 2026-04-30.
]

EXEMPTION_MARKER = "diecast-lint: ignore-line"

# Subdirectories the scanner skips by default (relative to --root).
#
# Note: only `tests/fixtures/forbidden/` is excluded. `tests/fixtures/planted/`
# is intentionally NOT excluded — the planted-fixture verification ritual
# (Gate G1.3.a) requires real CI failures from leak-files committed under
# that path. Use `--include-fixtures` to also scan `forbidden/`.
DEFAULT_SKIP_DIRS = {
    ".git",
    "node_modules",
    "__pycache__",
    ".venv",
    ".pytest_cache",
    "tests/fixtures/forbidden",
}

# Path-component prefixes that are always skipped.
DEFAULT_SKIP_PREFIXES = (".cast-bak-",)

# Always-excluded files (binary/lockfile noise; reduces false positives).
ALWAYS_SKIP_SUFFIXES = (".png", ".jpg", ".jpeg", ".gif", ".pdf", ".zip", ".gz", ".tar")


def _rel_components(path: Path, root: Path) -> List[str]:
    rel = path.relative_to(root).as_posix()
    return rel.split("/") if rel else []


def is_skipped_dir(dir_path: Path, root: Path, include_fixtures: bool) -> bool:
    """Return True iff a directory should be skipped during enumeration."""
    parts = _rel_components(dir_path, root)
    if not parts or parts == [""]:
        return False
    # Walk the path components from the root down; any prefix matching a
    # skip-dir entry kills the subtree.
    for i in range(1, len(parts) + 1):
        prefix = "/".join(parts[:i])
        if prefix in DEFAULT_SKIP_DIRS:
            if include_fixtures and prefix == "tests/fixtures/forbidden":
                continue
            return True
    for part in parts:
        if any(part.startswith(g) for g in DEFAULT_SKIP_PREFIXES):
            return True
    return False


def iter_files_git(root: Path, include_fixtures: bool) -> List[Path] | None:
    """Enumerate files via `git ls-files` (tracked + untracked, gitignore-aware).

    Returns None if `root` is not inside a git work tree.
    """
    try:
        # First confirm we're in a git repo.
        check = subprocess.run(
            ["git", "-C", str(root), "rev-parse", "--is-inside-work-tree"],
            capture_output=True,
            text=True,
        )
        if check.returncode != 0:
            return None
        result = subprocess.run(
            ["git", "-C", str(root), "ls-files", "-co", "--exclude-standard"],
            capture_output=True,
            text=True,
            check=True,
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        return None
    files: List[Path] = []
    for line in result.stdout.splitlines():
        if not line:
            continue
        p = (root / line).resolve()
        try:
            p.relative_to(root)
        except ValueError:
            continue
        if not p.is_file() or p.is_symlink():
            continue
        if any(line.lower().endswith(s) for s in ALWAYS_SKIP_SUFFIXES):
            continue
        if is_skipped_dir(p.parent, root, include_fixtures):
            continue
        files.append(p)
    return files


def iter_files_walk(root: Path, include_fixtures: bool) -> List[Path]:
    """Enumerate files via a `pathlib` walk, honoring DEFAULT_SKIP_DIRS."""
    files: List[Path] = []
    for p in root.rglob("*"):
        if not p.is_file() or p.is_symlink():
            continue
        if any(p.name.lower().endswith(s) for s in ALWAYS_SKIP_SUFFIXES):
            continue
        if is_skipped_dir(p.parent, root, include_fixtures):
            continue
        files.append(p)
    return files


def scan_file(
    path: Path,
    root: Path,
    compiled: List[Tuple[re.Pattern, str]],
) -> List[str]:
    """Return one hit message per matching line in `path`."""
    hits: List[str] = []
    try:
        with path.open("r", encoding="utf-8", errors="replace") as fh:
            for lineno, line in enumerate(fh, start=1):
                if EXEMPTION_MARKER in line:
                    continue
                for regex, source in compiled:
                    if regex.search(line):
                        rel = path.relative_to(root).as_posix()
                        hits.append(
                            f"{rel}:{lineno}: matched pattern '{source}' — "
                            f"anonymization rule X violated. "
                            f"See CONTRIBUTING.md > Anonymization."
                        )
                        # Don't break — multiple distinct patterns may match
                        # the same line; report each.
    except (OSError, UnicodeError):
        pass
    return hits


def main(argv: List[str] | None = None) -> int:
    ap = argparse.ArgumentParser(description="Anonymization lint for Diecast.")
    ap.add_argument("--root", default=".", help="Repo root to scan (default: cwd)")
    ap.add_argument(
        "--include-fixtures",
        action="store_true",
        help="Also scan tests/fixtures/forbidden/ (off by default).",
    )
    args = ap.parse_args(argv)

    root = Path(args.root).resolve()
    if not root.is_dir():
        print(f"error: --root {root} is not a directory", file=sys.stderr)
        return 2

    compiled = [(re.compile(pat, flags), pat) for pat, flags in FORBIDDEN_PATTERNS]

    started = time.monotonic()
    files = iter_files_git(root, args.include_fixtures)
    if files is None:
        files = iter_files_walk(root, args.include_fixtures)

    hits: List[str] = []
    for f in files:
        hits.extend(scan_file(f, root, compiled))

    elapsed = time.monotonic() - started

    if hits:
        for h in hits:
            print(h)
        print(f"\n{len(hits)} hit(s) in {len(files)} file(s) ({elapsed:.2f}s)", file=sys.stderr)
        return 1

    print(f"clean: 0 hits in {len(files)} file(s) ({elapsed:.2f}s)", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
