#!/usr/bin/env python3
"""cast-spec-checker — lint a spec doc against templates/cast-spec.template.md.

Internal use; not on user PATH. Invoked by the cast-spec-checker agent and CI.
Post-install user surface is the `/cast-spec-checker` slash command.

Validates BOTH cast-refine-requirements output AND cast-update-spec output.
The shape rules are documented in agents/cast-spec-checker/cast-spec-checker.md.

Exit codes:
  0 — no errors (warnings allowed, or --warn-only is set)
  1 — at least one error
  2 — invocation error (file not found, no path passed)
"""

from __future__ import annotations

import argparse
import re
import sys
from dataclasses import dataclass
from pathlib import Path

REQUIRED_SECTIONS = (
    "User Stories",
    "Functional Requirements",
    "Success Criteria",
    "Open Questions",
)

# ---------------------------------------------------------------------------
# Two-level family-aware checking (Refine Requirements v2, sub-phase 2c)
# ---------------------------------------------------------------------------
# MIRRORED copy of cast_server.requirements_render.families.REQUIRED_SECTIONS_BY_FAMILY.
#
# DELIBERATE DIVERGENCE (Decision D5): this checker is a portable, stdlib-only
# linter that must run in CI / pre-commit where the `cast-server` package is NOT
# importable. It therefore mirrors the per-family required-sections mapping as a
# literal dict instead of importing `families.py`. The pin test
# `cast-server/tests/test_spec_checker_family.py::test_mirror_matches_families`
# imports the real mapping and asserts this copy equals it as a FULL mapping
# (every family's exact section tuple), so the mirror can never silently drift.
#
# This is the OPPOSITE policy from `bin/cast-classify-gate`, which DOES import
# `families.py` because it is part of the classify orchestration. Do NOT "unify"
# the two bins — the divergence is intentional.
REQUIRED_SECTIONS_BY_FAMILY: dict[str, tuple[str, ...]] = {
    "new_initiative": (
        "Intent",
        "User Stories",
        "Functional Requirements",
        "Success Criteria",
        "Out of Scope",
    ),
    "pilot_poc": ("Intent", "Decisions"),
    "bug_fix": ("Intent", "Evidence"),
    "data_analysis": ("Intent", "Evidence"),
    "random_idea": ("Intent",),
    "testing_qa": ("Intent", "Evidence", "Out of Scope"),
    "refactor_migration": ("Intent", "Decisions", "Out of Scope"),
    "personal_non_eng": ("Intent",),
    "generic": ("Intent",),
}

# Floor families whose recipe offers NO spec-kit depth: a present-but-empty
# US/FR/SC/Out-of-Scope section is the Template-Enforcer anti-pattern and is an
# ERROR. Present-with-real-content is always fine — structure is *offered*,
# never auto-padded (Decision D2: random_idea is the structural floor).
_FLOOR_FAMILIES = ("random_idea", "personal_non_eng")
_SPEC_KIT_DEPTH_SECTIONS = (
    "User Stories",
    "Functional Requirements",
    "Success Criteria",
    "Out of Scope",
)
# Families for which HOW/Directional content is expected to be omitted (US1 S3):
# genuine content only WARNs (never errors).
_DIRECTIONAL_WARN_FAMILIES = ("data_analysis", "personal_non_eng")

# Level-1 generic regexes / tokens (additive; the re-exported grammar below is frozen).
H1_RE = re.compile(r"^#\s+\S")
_TABLE_SEP_RE = re.compile(r"^\s*\|?[\s:|-]*-[\s:|-]*\|?\s*$")
_PLACEHOLDER_TOKENS = frozenset(
    {"", "tbd", "tba", "todo", "n/a", "na", "none", "...", "…", "-", "—", "–"}
)

PRIORITY_RE = re.compile(r"\bPriority:\s*(P1|P2|P3)\b")
US_HEADING_RE = re.compile(r"^###\s+(US\S+)\s*[—-]\s*(.+)$")
INDEPENDENT_TEST_RE = re.compile(r"\*\*Independent test:?\*\*", re.IGNORECASE)
ACCEPTANCE_SCENARIO_HEADER_RE = re.compile(
    r"\*\*Acceptance scenarios?\b", re.IGNORECASE
)
EARS_SCENARIO_RE = re.compile(
    r"\bWHEN\b.+?\bTHE\s+SYSTEM\s+SHALL\b", re.IGNORECASE | re.DOTALL
)
NEEDS_CLAR_INLINE_RE = re.compile(r"\[NEEDS CLARIFICATION:\s*([^\]]+)\]")
FR_ID_RE = re.compile(r"\bFR-(\d{3,})\b")
SC_ID_RE = re.compile(r"\bSC-(\d{3,})\b")
SECTION_HEADING_RE = re.compile(r"^##\s+(.+?)\s*$")


@dataclass
class Finding:
    file: str
    line: int
    severity: str  # "error" | "warning"
    rule: str
    message: str

    def render(self) -> str:
        return f"{self.file}:{self.line}: {self.severity} {self.rule}: {self.message}"


def _section_spans(lines: list[str]) -> dict[str, tuple[int, int]]:
    """Map H2 section name -> (start_line, end_line) inclusive (1-indexed)."""
    spans: dict[str, tuple[int, int]] = {}
    current: tuple[str, int] | None = None
    for idx, raw in enumerate(lines, start=1):
        m = SECTION_HEADING_RE.match(raw.rstrip())
        if not m:
            continue
        name = m.group(1).strip()
        if current is not None:
            spans[current[0]] = (current[1], idx - 1)
        current = (name, idx)
    if current is not None:
        spans[current[0]] = (current[1], len(lines))
    return spans


def _collect_user_stories(
    lines: list[str], section_span: tuple[int, int]
) -> list[tuple[int, str, str, list[str]]]:
    """Return list of (start_line, identifier, heading_text, story_lines)."""
    start, end = section_span
    out: list[tuple[int, str, str, list[str]]] = []
    current: tuple[int, str, str, list[str]] | None = None
    for offset, raw in enumerate(lines[start - 1 : end]):
        line_no = start + offset
        m = US_HEADING_RE.match(raw.rstrip())
        if m:
            if current is not None:
                out.append(current)
            current = (line_no, m.group(1), m.group(2).strip(), [])
            continue
        if current is not None:
            current[3].append(raw)
    if current is not None:
        out.append(current)
    return out


def _section_body(lines: list[str], span: tuple[int, int]) -> list[str]:
    """Return a section's body lines (everything after its H2 heading line).

    ``span`` is the 1-indexed ``(heading_line, end_line)`` from ``_section_spans``;
    the slice ``lines[heading_line:end_line]`` skips the heading and keeps the body.
    """
    start, end = span
    return lines[start:end]


def _is_empty_or_placeholder(body_lines: list[str]) -> bool:
    """True when a section carries no real content.

    Blank lines, HTML comments, placeholder tokens (TBD/TODO/N/A/…), and a
    header-only table (separator + a single header row, zero data rows) all count
    as empty. Any prose line, or a table with at least one data row (>= 2
    non-separator rows), counts as real content.
    """
    table_nonsep_rows = 0
    for raw in body_lines:
        stripped = raw.strip()
        if not stripped or stripped.startswith("<!--"):
            continue
        if _TABLE_SEP_RE.match(stripped):
            continue
        if stripped.startswith("|"):
            table_nonsep_rows += 1
            continue
        token = stripped.strip("*_`[]() ").lower()
        if token in _PLACEHOLDER_TOKENS or token.startswith("needs clarification"):
            continue
        return False  # real prose content
    return table_nonsep_rows <= 1


def lint_spec(
    path: Path, *, warn_only: bool = False, family: str | None = None
) -> tuple[list[Finding], int]:
    if not path.exists():
        print(f"{path}: invocation-error: file not found", file=sys.stderr)
        return ([], 2)

    text = path.read_text(encoding="utf-8")
    lines = text.splitlines()
    spans = _section_spans(lines)
    findings: list[Finding] = []
    file_label = str(path)

    # Level 1 (always) — document title present (a top-level `# ` H1).
    if not any(H1_RE.match(raw) for raw in lines):
        findings.append(
            Finding(
                file=file_label,
                line=1,
                severity="error",
                rule="R8",
                message="missing document title (expected a top-level '# ' H1 heading)",
            )
        )

    # Required sections — no `--family` uses today's full-spec profile (R1,
    # byte-for-byte); `--family <value>` uses the per-family Level-2 profile (F1).
    if family is None:
        required_sections = REQUIRED_SECTIONS
        required_rule = "R1"
    else:
        required_sections = REQUIRED_SECTIONS_BY_FAMILY[family]
        required_rule = "F1"
    for required in required_sections:
        if required not in spans:
            findings.append(
                Finding(
                    file=file_label,
                    line=1,
                    severity="error",
                    rule=required_rule,
                    message=f"missing required section: ## {required}",
                )
            )

    # User-story-scoped checks need the User Stories section.
    user_stories_span = spans.get("User Stories")
    if user_stories_span is not None:
        stories = _collect_user_stories(lines, user_stories_span)
        if not stories:
            findings.append(
                Finding(
                    file=file_label,
                    line=user_stories_span[0],
                    severity="error",
                    rule="R1",
                    message="User Stories section has no '### USx — ...' entries",
                )
            )
        for line_no, ident, heading, body in stories:
            blob = "\n".join(body)

            # R2 — priority present
            if not (PRIORITY_RE.search(heading) or PRIORITY_RE.search(blob)):
                findings.append(
                    Finding(
                        file=file_label,
                        line=line_no,
                        severity="error",
                        rule="R2",
                        message=(
                            f'User Story "{ident}" missing Priority '
                            f"(expected one of P1|P2|P3)"
                        ),
                    )
                )

            # R3 — independent test line
            if not INDEPENDENT_TEST_RE.search(blob):
                findings.append(
                    Finding(
                        file=file_label,
                        line=line_no,
                        severity="warning",
                        rule="R3",
                        message=(
                            f'User Story "{ident}" missing **Independent test:** line'
                        ),
                    )
                )

            # R4 — at least one EARS-style acceptance scenario
            has_header = ACCEPTANCE_SCENARIO_HEADER_RE.search(blob) is not None
            has_ears = EARS_SCENARIO_RE.search(blob) is not None
            if not (has_header and has_ears):
                missing = []
                if not has_header:
                    missing.append("Acceptance scenarios header")
                if not has_ears:
                    missing.append("EARS-style 'WHEN ..., THE SYSTEM SHALL ...' line")
                findings.append(
                    Finding(
                        file=file_label,
                        line=line_no,
                        severity="error",
                        rule="R4",
                        message=(
                            f'User Story "{ident}" missing '
                            + " and ".join(missing)
                        ),
                    )
                )

    # R5 — duplicate FR / SC identifiers within the spec
    fr_seen: dict[str, int] = {}
    sc_seen: dict[str, int] = {}
    for idx, raw in enumerate(lines, start=1):
        for match in FR_ID_RE.finditer(raw):
            ident = f"FR-{match.group(1)}"
            if ident in fr_seen and "|" in raw:
                # Only flag table rows (definitions) as duplicates, not prose refs.
                findings.append(
                    Finding(
                        file=file_label,
                        line=idx,
                        severity="error",
                        rule="R5",
                        message=(
                            f"duplicate functional-requirement identifier {ident} "
                            f"(first defined at line {fr_seen[ident]})"
                        ),
                    )
                )
            elif "|" in raw:
                fr_seen.setdefault(ident, idx)
        for match in SC_ID_RE.finditer(raw):
            ident = f"SC-{match.group(1)}"
            if ident in sc_seen and "|" in raw:
                findings.append(
                    Finding(
                        file=file_label,
                        line=idx,
                        severity="error",
                        rule="R5",
                        message=(
                            f"duplicate success-criterion identifier {ident} "
                            f"(first defined at line {sc_seen[ident]})"
                        ),
                    )
                )
            elif "|" in raw:
                sc_seen.setdefault(ident, idx)

    # R6 — orphan [NEEDS CLARIFICATION] markers
    open_q_span = spans.get("Open Questions")
    open_q_blob = ""
    if open_q_span is not None:
        open_q_blob = "\n".join(lines[open_q_span[0] - 1 : open_q_span[1]])
    open_q_topics: set[str] = set(
        m.group(1).strip().lower() for m in NEEDS_CLAR_INLINE_RE.finditer(open_q_blob)
    )

    # We deliberately exempt blocks that are illustrative worked examples
    # (i.e., live under an H2 starting with "Worked Example").
    worked_example_spans: list[tuple[int, int]] = [
        span for name, span in spans.items() if name.lower().startswith("worked example")
    ]

    def _in_worked_example(line_no: int) -> bool:
        return any(start <= line_no <= end for start, end in worked_example_spans)

    for idx, raw in enumerate(lines, start=1):
        if open_q_span is not None and open_q_span[0] <= idx <= open_q_span[1]:
            continue
        if _in_worked_example(idx):
            continue
        for match in NEEDS_CLAR_INLINE_RE.finditer(raw):
            topic = match.group(1).strip().lower()
            if topic not in open_q_topics:
                findings.append(
                    Finding(
                        file=file_label,
                        line=idx,
                        severity="error",
                        rule="R6",
                        message=(
                            f"orphan [NEEDS CLARIFICATION: {match.group(1).strip()}] — "
                            f"add a matching entry in the Open Questions section"
                        ),
                    )
                )

    # R7 — no mixed shape (FR/SC tables present but no User Stories section)
    has_fr_or_sc = any(FR_ID_RE.search(line) or SC_ID_RE.search(line) for line in lines)
    if has_fr_or_sc and "User Stories" not in spans:
        findings.append(
            Finding(
                file=file_label,
                line=1,
                severity="error",
                rule="R7",
                message=(
                    "spec has FR-NNN or SC-NNN identifiers but no User Stories "
                    "section — half-migrated shape detected"
                ),
            )
        )

    # Level 2 — family-specific assertions (only when `--family` is passed).
    if family is not None:
        # Template-Enforcer guard: a floor family must not carry padded, empty
        # spec-kit sections. Its recipe offers no such depth to fill.
        if family in _FLOOR_FAMILIES:
            for name in _SPEC_KIT_DEPTH_SECTIONS:
                span = spans.get(name)
                if span is not None and _is_empty_or_placeholder(
                    _section_body(lines, span)
                ):
                    findings.append(
                        Finding(
                            file=file_label,
                            line=span[0],
                            severity="error",
                            rule="F2",
                            message=(
                                f'family "{family}" carries an empty/placeholder '
                                f"## {name} section — this family's recipe offers no "
                                f"spec-kit depth to pad (remove it or add real content)"
                            ),
                        )
                    )
        # Directional/HOW content is expected omitted for these families; genuine
        # content WARNs (never errors).
        if family in _DIRECTIONAL_WARN_FAMILIES:
            for name, span in spans.items():
                if name.lower().startswith("directional"):
                    findings.append(
                        Finding(
                            file=file_label,
                            line=span[0],
                            severity="warning",
                            rule="F3",
                            message=(
                                f'family "{family}" usually omits HOW — found a '
                                f"## {name} section (allowed, but verify it is intended)"
                            ),
                        )
                    )

    has_error = any(f.severity == "error" for f in findings)
    if warn_only:
        exit_code = 0
    else:
        exit_code = 1 if has_error else 0
    return findings, exit_code


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="cast-spec-checker",
        description=(
            "Lint spec documents against templates/cast-spec.template.md. "
            "Validates both cast-refine-requirements output and "
            "cast-update-spec output."
        ),
    )
    parser.add_argument("paths", nargs="+", help="Spec doc paths")
    parser.add_argument(
        "--warn-only",
        action="store_true",
        help="Exit 0 even if errors are present (v1.0 rollout flag).",
    )
    parser.add_argument(
        "--family",
        default=None,
        metavar="VALUE",
        help=(
            "Apply the per-family Level-2 required-section profile and assertions "
            "for the given WorkFamily value (e.g. bug_fix, random_idea). Omit for "
            "the full-spec (no-family) path, which is unchanged."
        ),
    )
    args = parser.parse_args(argv)

    if args.family is not None and args.family not in REQUIRED_SECTIONS_BY_FAMILY:
        valid = ", ".join(sorted(REQUIRED_SECTIONS_BY_FAMILY))
        print(
            f"cast-spec-checker: invocation-error: unknown --family "
            f"{args.family!r} (valid: {valid})",
            file=sys.stderr,
        )
        return 2

    overall_exit = 0
    for raw_path in args.paths:
        path = Path(raw_path)
        findings, code = lint_spec(
            path, warn_only=args.warn_only, family=args.family
        )
        for finding in findings:
            print(finding.render())
        if code > overall_exit:
            overall_exit = code
    return overall_exit


if __name__ == "__main__":
    raise SystemExit(main())
