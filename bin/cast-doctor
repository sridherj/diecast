#!/usr/bin/env bash
# SPDX-License-Identifier: Apache-2.0
# bin/cast-doctor — Diecast prerequisite checker.
#
# Internal: invoked by `setup`'s `step1_doctor` and CI. Post-install diagnosis
# happens via `/cast-doctor` from inside Claude Code.
# Exits 0 when no RED findings; non-zero with per-issue actionable messages otherwise.
#
# Usage:
#   bin/cast-doctor                # human-readable output, exit 0/1
#   bin/cast-doctor --json         # minimal JSON: {"red":[...],"yellow":[...],"green":[...]}
#   bin/cast-doctor --quiet        # suppress GREEN lines; print RED/YELLOW only
#   bin/cast-doctor --fix-terminal # internal: invoked by `setup` and the `/cast-doctor`
#                                  # skill; users should run `/cast-doctor` from inside
#                                  # Claude Code.
#   bin/cast-doctor --help         # this help text
#
# Required green prerequisites:
#   * bash >= 4.0          (Decision #4 — Alpine: apk add bash; macOS: brew install bash)
#   * uv   >= 0.4.0        (curl -LsSf https://astral.sh/uv/install.sh | sh)
#   * git  >= 2.30
#   * claude on PATH       (https://claude.com/claude-code)
#   * write access to ~/.claude/ and ~/.cast/
#
# Yellow (warn-only) checks:
#   * $CAST_TERMINAL set to a value not in the supported list (soft-fallback per Decision #3)
#   * $CAST_TERMINAL empty, $TERMINAL empty, no supported terminal on PATH
#   * cast-hook not installed at project- or user-scope when cwd looks like a project
#     (without it the /runs tree drops user-typed /cast-* commands as parent rows)
#
# Direct callability (Decision #2): this script is intentionally usable post-install.
# The setup wrapper sources bin/_lib.sh and then invokes us; standalone callers do
# the same automatically via the SCRIPT_DIR resolution below.

set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
# shellcheck source=bin/_lib.sh
source "${SCRIPT_DIR}/_lib.sh"

JSON_OUTPUT=0
QUIET=0
FIX_TERMINAL=0
# KEEP IN SYNC WITH _SUPPORTED in agents/_shared/terminal.py.
# CI parity test (tests/test_cast_doctor.py::test_fallback_list_matches_supported)
# asserts equality. Used only when python3 / agents._shared.terminal is not
# importable (e.g., install-time gate before deps are installed).
SUPPORTED_TERMINALS_FALLBACK=(ptyxis gnome-terminal kitty alacritty iterm terminal)

print_help() {
  cat <<'EOF'
bin/cast-doctor — Diecast prerequisite checker.

Internal: invoked by `setup`'s `step1_doctor` and CI. Post-install diagnosis
happens via `/cast-doctor` from inside Claude Code.
Exits 0 when no RED findings; non-zero with per-issue actionable messages otherwise.

Usage:
  bin/cast-doctor                # human-readable output, exit 0/1
  bin/cast-doctor --json         # minimal JSON: {"red":[...],"yellow":[...],"green":[...]}
  bin/cast-doctor --quiet        # suppress GREEN lines; print RED/YELLOW only
  bin/cast-doctor --fix-terminal # internal: invoked by `setup` and the `/cast-doctor`
                                 # skill; users should run `/cast-doctor` from inside
                                 # Claude Code.
  bin/cast-doctor --help         # this help text

Required green prerequisites:
  * bash >= 4.0          (Decision #4 — Alpine: apk add bash; macOS: brew install bash)
  * uv   >= 0.4.0        (curl -LsSf https://astral.sh/uv/install.sh | sh)
  * git  >= 2.30
  * claude on PATH       (https://claude.com/claude-code)
  * write access to ~/.claude/ and ~/.cast/

Yellow (warn-only) checks:
  * $CAST_TERMINAL set to a value not in the supported list (soft-fallback per Decision #3)
  * $CAST_TERMINAL empty, $TERMINAL empty, no supported terminal on PATH

Direct callability (Decision #2): this script is intentionally usable post-install
as a fallback — it's the gate ./setup runs in Step 1, and it backs the
`/cast-doctor` skill when cast-server is down.
EOF
}

while (($#)); do
  case "$1" in
    --json)         JSON_OUTPUT=1 ;;
    --quiet)        QUIET=1 ;;
    --fix-terminal) FIX_TERMINAL=1 ;;
    -h|--help)      print_help; exit 0 ;;
    *)              fail "Unknown flag: $1 (try --help)" ;;
  esac
  shift
done

declare -a RED=()
declare -a YELLOW=()
declare -a GREEN=()

note_red()    { RED+=("$1"); }
note_yellow() { YELLOW+=("$1"); }
note_green()  { GREEN+=("$1"); }

# get_supported_terminals
#   Echo space-separated supported terminal keys. Prefers the canonical Python
#   source of truth (`agents._shared.terminal._SUPPORTED.keys()`); falls back
#   to the hardcoded SUPPORTED_TERMINALS_FALLBACK array when python3 / the
#   agents package is not importable (e.g., install-time gate before deps are
#   installed).
get_supported_terminals() {
  if command -v python3 >/dev/null 2>&1; then
    local out
    out=$(python3 -c '
import sys
sys.path.insert(0, "'"${SCRIPT_DIR}"'/..")
try:
    from agents._shared.terminal import _SUPPORTED
    print(" ".join(_SUPPORTED.keys()))
except Exception:
    sys.exit(2)
' 2>/dev/null) && [[ -n "$out" ]] && { echo "$out"; return; }
  fi
  echo "${SUPPORTED_TERMINALS_FALLBACK[*]}"
}

# ── Version helpers ────────────────────────────────────────────────
# version_ge "A.B.C" "X.Y.Z" → exit 0 when A.B.C >= X.Y.Z (semantic, dot-segment).
version_ge() {
  local have="$1" want="$2"
  local IFS=.
  # shellcheck disable=SC2206  # word-splitting on '.' is intentional (IFS set above)
  local -a a=($have) b=($want)
  local i
  for ((i=0; i<${#b[@]}; i++)); do
    local av="${a[i]:-0}" bv="${b[i]}"
    av="${av//[^0-9]/}"; bv="${bv//[^0-9]/}"
    : "${av:=0}"; : "${bv:=0}"
    if (( 10#$av > 10#$bv )); then return 0; fi
    if (( 10#$av < 10#$bv )); then return 1; fi
  done
  return 0
}

extract_version() {
  printf '%s' "$1" | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1
}

# ── Checks ─────────────────────────────────────────────────────────
check_bash() {
  local ver="${BASH_VERSION%%[!0-9.]*}"
  if [[ -n "$ver" ]] && version_ge "$ver" "4.0"; then
    note_green "bash ${ver}"
  else
    note_red "bash ${ver:-unknown} found (need >= 4.0). Install bash >= 4.0. On Alpine: apk add bash. On macOS: brew install bash."
  fi
}

# install_hint_python3 / install_hint_tmux
#   Echo the OS-appropriate install command (no surrounding text). Callers
#   embed the result in note_red messages — matches the inline-hint style
#   used by check_bash / check_uv / check_git.
install_hint_python3() {
  case "$(uname -s)" in
    Darwin) printf 'brew install python@3.11' ;;
    Linux)
      if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        case "${ID:-}${ID_LIKE:-}" in
          *debian*|*ubuntu*) printf 'sudo apt install python3.11' ;;
          *rhel*|*fedora*|*centos*) printf 'sudo dnf install python3.11' ;;
          *arch*) printf 'sudo pacman -S python' ;;
          *) printf 'install python >= 3.11 via your package manager' ;;
        esac
      else
        printf 'install python >= 3.11 via your package manager'
      fi
      ;;
    *) printf 'install python >= 3.11 via your package manager' ;;
  esac
}

install_hint_tmux() {
  case "$(uname -s)" in
    Darwin) printf 'brew install tmux' ;;
    Linux)
      if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        case "${ID:-}${ID_LIKE:-}" in
          *debian*|*ubuntu*) printf 'sudo apt install tmux' ;;
          *rhel*|*fedora*|*centos*) printf 'sudo dnf install tmux' ;;
          *arch*) printf 'sudo pacman -S tmux' ;;
          *) printf 'install tmux via your package manager' ;;
        esac
      else
        printf 'install tmux via your package manager'
      fi
      ;;
    *) printf 'install tmux via your package manager' ;;
  esac
}

check_python3() {
  if ! command -v python3 >/dev/null 2>&1; then
    note_red "python3 not found (need >= 3.11). Install: $(install_hint_python3)"
    return
  fi
  local raw ver
  raw="$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}")' 2>&1 || true)"
  ver="$(extract_version "$raw")"
  if [[ -n "$ver" ]] && version_ge "$ver" "3.11"; then
    note_green "python3 ${ver}"
  else
    note_red "python3 ${ver:-unknown} found (need >= 3.11). Install: $(install_hint_python3)"
  fi
}

check_tmux() {
  if ! command -v tmux >/dev/null 2>&1; then
    note_red "tmux not found (required by the dispatcher). Install: $(install_hint_tmux)"
    return
  fi
  local raw ver
  raw="$(tmux -V 2>&1 || true)"
  ver="$(extract_version "$raw")"
  note_green "tmux ${ver:-present}"
}

check_uv() {
  if ! command -v uv >/dev/null 2>&1; then
    note_red "uv not found. Install uv: curl -LsSf https://astral.sh/uv/install.sh | sh"
    return
  fi
  local raw ver
  raw="$(uv --version 2>&1 || true)"
  ver="$(extract_version "$raw")"
  if [[ -n "$ver" ]] && version_ge "$ver" "0.4.0"; then
    note_green "uv ${ver}"
  else
    note_red "uv ${ver:-unknown} found (need >= 0.4.0). Upgrade uv: curl -LsSf https://astral.sh/uv/install.sh | sh"
  fi
}

check_git() {
  if ! command -v git >/dev/null 2>&1; then
    note_red "git not found. Install git >= 2.30 (apt: sudo apt-get install git; macOS: brew install git)."
    return
  fi
  local raw ver
  raw="$(git --version 2>&1 || true)"
  ver="$(extract_version "$raw")"
  if [[ -n "$ver" ]] && version_ge "$ver" "2.30"; then
    note_green "git ${ver}"
  else
    note_red "git ${ver:-unknown} found (need >= 2.30). Upgrade git from your package manager."
  fi
}

check_claude() {
  if command -v claude >/dev/null 2>&1; then
    note_green "claude on PATH ($(command -v claude))"
  else
    note_red "claude not on PATH. Install Claude Code from https://claude.com/claude-code"
  fi
}

check_writable() {
  local dir="$1"
  if [[ "${DRY_RUN}" == "1" ]]; then
    note_green "${dir} (DRY: not creating)"
    return
  fi
  mkdir -p "$dir" 2>/dev/null || {
    note_red "${dir} not writable. chmod/chown so your user can create it."
    return
  }
  if [[ -w "$dir" ]]; then
    note_green "${dir} writable"
  else
    note_red "${dir} not writable. chmod/chown so your user can create it."
  fi
}

# Yellow-only — cast-hook is functional without per-project install (cast-server
# still serves the API, agent dispatches still work) but the runs-tree won't
# capture user-typed /cast-* commands as parent rows. The grep pattern matches
# the absolute-path command shape that install_hooks.py writes (resolved
# through ~/.claude/skills/diecast/bin/cast-hook).
check_cast_hooks() {
  local cwd
  cwd="$(pwd)"
  local proj_settings="${cwd}/.claude/settings.json"
  local user_settings="${HOME}/.claude/settings.json"
  local needle="${HOME}/.claude/skills/diecast/bin/cast-hook "

  local proj_has=0
  local user_has=0
  [[ -f "${proj_settings}" ]] && grep -qF "${needle}" "${proj_settings}" 2>/dev/null && proj_has=1
  [[ -f "${user_settings}" ]] && grep -qF "${needle}" "${user_settings}" 2>/dev/null && user_has=1

  if [[ "${proj_has}" -eq 1 ]]; then
    note_green "cast-hook installed at project scope (${proj_settings})"
    return
  fi
  if [[ "${user_has}" -eq 1 ]]; then
    note_green "cast-hook installed at user scope (${user_settings})"
    return
  fi

  # Neither scope has it. Only flag YELLOW when cwd looks like a project
  # (Diecast-managed or otherwise) — bare shells get nothing because there's
  # nothing to install into.
  if [[ -d "${cwd}/.claude" || -d "${cwd}/.git" || -f "${cwd}/pyproject.toml" || -f "${cwd}/package.json" ]]; then
    note_yellow "cast-hook not installed for this project. Without it the /runs page won't show user-typed /cast-* commands as parent rows. Fix: run \`~/.claude/skills/diecast/bin/cast-hook install\` in this directory (add --user for global scope). Re-run /cast-init also wires this automatically."
  fi
}

# Yellow-only — verify the diecast skill-root symlink that resolves cast-hook
# (and cast-server) is in place. Missing it means hook entries written by the
# installer point at a non-existent binary; rerun ./setup to repair.
check_diecast_skill_root() {
  local target="${HOME}/.claude/skills/diecast"
  local hook_bin="${target}/bin/cast-hook"
  if [[ ! -L "${target}" ]]; then
    note_yellow "~/.claude/skills/diecast is not a symlink. Run ./setup --upgrade from the diecast repo to install it."
    return
  fi
  if [[ ! -x "${hook_bin}" ]]; then
    note_yellow "${hook_bin} is missing or not executable. The diecast skill-root symlink points at $(readlink "${target}"). Run ./setup --upgrade to repair."
    return
  fi
  note_green "diecast skill root linked (${target} -> $(readlink "${target}"))"
}

is_supported_terminal() {
  local needle="$1"
  local t
  for t in $(get_supported_terminals); do
    [[ "$needle" == "$t" ]] && return 0
  done
  return 1
}

check_terminal() {
  local cast="${CAST_TERMINAL:-}"
  local sysnal="${TERMINAL:-}"
  local supported_str
  supported_str=$(get_supported_terminals)

  if [[ -n "$cast" ]]; then
    if is_supported_terminal "$cast"; then
      note_green "\$CAST_TERMINAL=${cast} (supported)"
      return
    fi
    note_yellow "\$CAST_TERMINAL=${cast} is not a supported terminal. Run \`/cast-doctor\` from inside Claude Code to probe and configure (or \`bin/cast-doctor --fix-terminal\` from a shell as fallback), or set \$CAST_TERMINAL to one of: ${supported_str}. See docs/reference/supported-terminals.md."
    return
  fi

  if [[ -n "$sysnal" ]]; then
    note_green "\$TERMINAL=${sysnal} (will be used as fallback)"
    return
  fi

  local t
  for t in $supported_str; do
    if command -v "$t" >/dev/null 2>&1; then
      note_green "supported terminal on PATH: ${t}"
      return
    fi
  done

  note_yellow "No supported terminal found. Run \`/cast-doctor\` from inside Claude Code to probe and configure (or \`bin/cast-doctor --fix-terminal\` from a shell as fallback), or set \$CAST_TERMINAL manually. (Supported: ${supported_str})"
}

# fix_terminal — interactive first-run setup.
#   Probes installed terminals on PATH (or /Applications on macOS), prompts the
#   user when there are multiple candidates, asks for confirmation when there's
#   exactly one, and writes terminal_default to ~/.cast/config.yaml.
#   Idempotent: re-running replaces the value cleanly and preserves other keys.
fix_terminal() {
  local sys_name
  sys_name=$(uname -s)
  printf '[cast-doctor] Probing supported terminals on PATH...\n'

  local -a candidates=()
  local supported_str
  supported_str=$(get_supported_terminals)

  if [[ "$sys_name" == "Darwin" ]]; then
    if [[ -d "/Applications/iTerm.app" ]]; then
      candidates+=(iterm)
      printf '  found: iterm (/Applications/iTerm.app)\n'
    fi
    candidates+=(terminal)  # always present on macOS
    printf '  found: terminal (built-in)\n'
  else
    # Linux / BSD / WSL — probe via `command -v` in _SUPPORTED-table order.
    # Bump konsole to the front when KDE is detected (only meaningful when
    # konsole is in _SUPPORTED — currently dormant).
    local desktop="${XDG_CURRENT_DESKTOP^^}"
    local order_str="$supported_str"
    if [[ "$desktop" == *KDE* && " $supported_str " == *" konsole "* ]]; then
      order_str="konsole $(echo "$supported_str" | tr ' ' '\n' | grep -v '^konsole$' | tr '\n' ' ')"
    fi
    local t path
    for t in $order_str; do
      # Skip macOS-only keys.
      [[ "$t" == "iterm" || "$t" == "terminal" ]] && continue
      if path=$(command -v "$t" 2>/dev/null) && [[ -n "$path" ]]; then
        candidates+=("$t")
        printf '  found: %s (%s)\n' "$t" "$path"
      fi
    done
  fi

  if [[ ${#candidates[@]} -eq 0 ]]; then
    printf '\n[cast-doctor] No supported terminal found on PATH.\n'
    if [[ "$sys_name" == "Darwin" ]]; then
      printf '  install iTerm2: brew install --cask iterm2\n'
    else
      printf '  install one of: %s\n' "$supported_str"
      printf '  e.g. on Debian/Ubuntu: sudo apt install gnome-terminal\n'
    fi
    return 1
  fi

  local choice
  if [[ ${#candidates[@]} -eq 1 ]]; then
    printf '\n[cast-doctor] One candidate found: %s\n' "${candidates[0]}"
    printf 'Write ~/.cast/config.yaml with terminal_default: %s? [Y/n] ' "${candidates[0]}"
    read -r choice
    case "${choice:-y}" in
      [yY]|[yY][eE][sS]) choice="${candidates[0]}" ;;
      *) printf '[cast-doctor] Aborted, no changes written.\n'; return 1 ;;
    esac
  else
    printf '\nMultiple candidates. Pick one:\n'
    local i=1
    for c in "${candidates[@]}"; do
      printf '  %d) %s\n' "$i" "$c"
      i=$((i + 1))
    done
    printf '\nChoice [1]: '
    read -r choice
    choice="${choice:-1}"
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#candidates[@]} )); then
      printf '[cast-doctor] Invalid choice: %s\n' "$choice"
      return 1
    fi
    choice="${candidates[$((choice - 1))]}"
  fi

  local cfg_dir="${HOME}/.cast"
  local cfg_file="${cfg_dir}/config.yaml"
  mkdir -p "$cfg_dir"

  # Idempotent write: replace just the terminal_default key, preserving other
  # keys. We rewrite the file via python3 to avoid hand-rolling YAML in bash.
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$cfg_file" "$choice" <<'PY'
import sys
from pathlib import Path
import yaml

path, choice = Path(sys.argv[1]), sys.argv[2]
data = {}
if path.exists():
    try:
        loaded = yaml.safe_load(path.read_text()) or {}
        if isinstance(loaded, dict):
            data = loaded
    except yaml.YAMLError:
        pass
data["terminal_default"] = choice
path.write_text(yaml.safe_dump(data, default_flow_style=False, sort_keys=True))
PY
  else
    # python3 missing — write a minimal one-key file. Existing keys would be
    # lost, but this branch only fires before the user's first dep install.
    printf 'terminal_default: %s\n' "$choice" > "$cfg_file"
  fi

  printf '\n[cast-doctor] Wrote %s: terminal_default: %s\n' "$cfg_file" "$choice"
  printf '[cast-doctor] Done. Verify with: cast-doctor\n'
}

# ── --fix-terminal short-circuit ───────────────────────────────────
# When the user asked for first-run setup, run only that flow and exit.
# Skips the prerequisite checks below — those are the diagnostic path.
if [[ "${FIX_TERMINAL}" -eq 1 ]]; then
  fix_terminal
  exit $?
fi

# ── Run all checks ─────────────────────────────────────────────────
check_bash
check_python3
check_tmux
check_uv
check_git
check_claude
check_writable "${HOME}/.claude"
check_writable "${HOME}/.cast"
check_terminal
check_diecast_skill_root
check_cast_hooks

# ── Output ─────────────────────────────────────────────────────────
emit_json() {
  local first
  printf '{"red":['
  first=1
  for item in "${RED[@]}"; do
    [[ $first -eq 1 ]] && first=0 || printf ','
    printf '%s' "$(printf '%s' "$item" | python3 -c 'import json,sys;print(json.dumps(sys.stdin.read()))')"
  done
  printf '],"yellow":['
  first=1
  for item in "${YELLOW[@]}"; do
    [[ $first -eq 1 ]] && first=0 || printf ','
    printf '%s' "$(printf '%s' "$item" | python3 -c 'import json,sys;print(json.dumps(sys.stdin.read()))')"
  done
  printf '],"green":['
  first=1
  for item in "${GREEN[@]}"; do
    [[ $first -eq 1 ]] && first=0 || printf ','
    printf '%s' "$(printf '%s' "$item" | python3 -c 'import json,sys;print(json.dumps(sys.stdin.read()))')"
  done
  printf ']}\n'
  unset sep
}

emit_human() {
  local item
  if [[ "${QUIET}" -eq 0 ]]; then
    for item in "${GREEN[@]}"; do printf '  [GREEN] %s\n' "$item"; done
  fi
  for item in "${YELLOW[@]}"; do printf '  [YELLOW] %s\n' "$item" >&2; done
  for item in "${RED[@]}"; do printf '  [RED] %s\n' "$item" >&2; done
  if [[ ${#RED[@]} -eq 0 ]]; then
    [[ "${QUIET}" -eq 0 ]] && printf '\n[cast-doctor] All required prerequisites satisfied.\n'
  else
    printf '\n[cast-doctor] %d required prerequisite(s) missing.\n' "${#RED[@]}" >&2
  fi
}

if [[ "${JSON_OUTPUT}" -eq 1 ]]; then
  emit_json
else
  emit_human
fi

[[ ${#RED[@]} -eq 0 ]] || exit 1
exit 0
