#!/usr/bin/env python3
# SPDX-License-Identifier: Apache-2.0
# bin/cast-doctor — Diecast prerequisite checker.
#
# Thin wrapper over cast_server.bootstrap.doctor.  Preserves the same
# command-line interface and exit-code contract as the previous bash
# implementation.
#
# Internal: invoked by `setup`'s `step1_doctor` and CI.  Post-install
# diagnosis happens via `/cast-doctor` from inside Claude Code.
# Exits 0 when no RED findings; non-zero with per-issue actionable
# messages otherwise.
#
# Usage:
#   bin/cast-doctor                # human-readable output, exit 0/1
#   bin/cast-doctor --json         # minimal JSON: {"red":[...],"yellow":[...],"green":[...]}
#   bin/cast-doctor --quiet        # suppress GREEN lines; print RED/YELLOW only
#   bin/cast-doctor --fix-terminal # internal: invoked by `setup` and the `/cast-doctor`
#                                  # skill; users should run `/cast-doctor` from inside
#                                  # Claude Code.
#   bin/cast-doctor --help         # this help text
#
# Direct callability (Decision #2): this script is intentionally usable
# post-install.  The setup wrapper calls us; standalone callers do the same.

import os
import sys
from pathlib import Path

# Resolve the repo root so we can import the bootstrap package without
# requiring it to be installed (bootstrap runs before `uv sync`).
_SCRIPT_DIR = Path(__file__).resolve().parent
_REPO_DIR = _SCRIPT_DIR.parent
_CAST_SERVER_DIR = _REPO_DIR / "cast-server"

# Add cast-server/ to sys.path so `cast_server.bootstrap.doctor` is importable.
if str(_CAST_SERVER_DIR) not in sys.path:
    sys.path.insert(0, str(_CAST_SERVER_DIR))

from cast_server.bootstrap.doctor import main  # noqa: E402

if __name__ == "__main__":
    main()
else:
    # Imported as a module or exec'd by a shell — still run.
    main()
